{
  "name": "furnishes_prod",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "predev": "prisma generate",
    "dev": "next dev",
    "dev:clean": "prisma generate && node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch{}\" && next dev",
    "build": "prisma generate && next build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create-only": "prisma migrate dev --create-only --name pending_schema_changes",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node -e \"console.error('Use db:seed:dev for local development. Production seeding is disabled.'); process.exit(1);\"",
    "db:seed:dev": "prisma db seed",
    "db:seed:rag": "tsx scripts/seed-rag.ts",
    "db:seed:rag:embed": "cross-env SEED_RAG=1 tsx scripts/seed-rag.ts",
    "db:studio": "prisma studio",
    "db:status": "prisma migrate status",
    "verify:prod": "tsx scripts/verify-prod.ts",
    "verify:prod:local": "cross-env DOTENV_CONFIG_PATH=.env.local tsx scripts/verify-prod.ts",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "images:optimize": "node scripts/optimize-public-images.mjs",
    "start": "next start",
    "check": "npm run typecheck && npm run format:check && npm run lint && npm run test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.37",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@fal-ai/client": "^1.9.5",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@sentry/nextjs": "^10.48.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.105",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "inngest": "^3.54.2",
    "input-otp": "^1.4.2",
