# Copy to `.env.local` for local development. Do not commit real secrets.

# --- Prisma (PostgreSQL after studio merge; SQLite migrations archived under prisma/migrations_sqlite_archived) ---
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
#
# Local SQLite is no longer the active datasource in schema.prisma.

# --- Fal.ai (furniture 2D→3D pipeline; server only) ---
# FAL_KEY=

# --- Rate limits (production): Upstash Redis for strict limits (auth, uploads, checkout, furniture) ---
# Without these, limits are in-memory per server instance (see startup log in production).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Eva chat + extraction (server only; never NEXT_PUBLIC_*) ---
# OPENAI_API_KEY=
# Optional: OpenRouter instead of OpenAI (same SDK; base URL switches in code).
# OPENROUTER_API_KEY=
# Optional OpenRouter headers (defaults: NEXTAUTH_URL or localhost, NEXT_PUBLIC_APP_NAME):
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_TITLE=Furnishes
# Optional model slugs (OpenRouter uses `provider/model`, e.g. `openai/gpt-4o-mini`):
# OPENROUTER_PRIMARY_MODEL=openai/gpt-4o-mini
# OPENROUTER_FALLBACK_MODEL=openai/gpt-4o
# Optional: try this model first when the chat stream is empty (non-streaming recovery).
# OPENROUTER_RECOVERY_EXTRA_MODEL=openai/gpt-4o

# --- App / marketing ---
# NEXT_PUBLIC_APP_NAME=Furnishes
# Commerce — UI/nav (client). Default off until ready.
# NEXT_PUBLIC_COMMERCE_ENABLED=1
# Server: required to enable POST /api/checkout/intent and other commerce APIs.
# Set to 0 to keep APIs off while NEXT_PUBLIC shows commerce UI (not recommended long-term).
# COMMERCE_BACKEND_ENABLED=1

# Optional: after Stripe payment, Inngest POSTs JSON to your warehouse / 3PL. Non-2xx fails the step (retries).
# FULFILLMENT_WEBHOOK_URL=https://your-wms.example/hooks/furnishes
# FULFILLMENT_WEBHOOK_SECRET=

# Base URL for absolute links (emails, webhooks, NextAuth). Also: AUTH_URL, PUBLIC_SITE_URL (aliases).
# On Vercel, VERCEL_URL is used if these are unset. getPublicOrigin() merges these rules.
# NEXTAUTH_URL=http://localhost:3000

# --- NextAuth / Auth.js (Credentials + optional Google). Required in production for JWT signing. ---
# AUTH_SECRET=generate-with-openssl-rand-base64-32
# NEXTAUTH_SECRET= (legacy alias for AUTH_SECRET)
# Mock auth: server honors cookie only when ALLOW_MOCK_AUTH=1 (never use NEXT_PUBLIC_* for server auth).
# Client demo affordances: NEXT_PUBLIC_MOCK_AUTH=1 (pair with ALLOW_MOCK_AUTH in prod demos).
# ALLOW_MOCK_AUTH=1
# NEXT_PUBLIC_MOCK_AUTH=1
# Support: in production never falls back to in-memory store unless:
# SUPPORT_MEMORY_FALLBACK=1
# Optional OAuth:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Optional: require NextAuth session for /api/* (see root middleware.ts). Default: anonymous API OK.
# EVA_REQUIRE_API_AUTH=true

# Share links (POST /api/conversations/:id/share): expiry for new links (1–365 days, default 30).
# SHARE_LINK_TTL_DAYS=30
# Production: getPublicOrigin() throws if no NEXTAUTH_URL / AUTH_URL / PUBLIC_SITE_URL / VERCEL_URL.
# Emergency only — allow localhost fallback for broken proxy config (not for real users):
# ALLOW_PUBLIC_ORIGIN_LOCALHOST_FALLBACK=1
# CSP: single source of truth is lib/site/content-security-policy.ts via next.config.ts headers (production).

# --- Admin / ops ---
# GET /api/admin/stats — admin role session, OR Authorization: Bearer <secret>
# ADMIN_STATS_SECRET=

# --- Sentry (optional; only initializes when NEXT_PUBLIC_SENTRY_DSN is set) ---
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- Cloudflare R2 (direct browser upload: /api/uploads/sign → PUT → /api/uploads/confirm) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=furnishes-uploads
# Public base URL for stored objects (required for File URLs after confirm), e.g. https://pub-xxx.r2.dev or your custom domain
# R2_PUBLIC_URL=
# Eva chat: use R2 presign → PUT → confirm instead of POST /api/upload (requires R2 + R2_PUBLIC_URL above)
# NEXT_PUBLIC_USE_R2_UPLOADS=1
# Dev only: reject legacy POST /api/upload when set. Production always blocks local disk upload.
# DISABLE_LOCAL_DISK_UPLOAD=1

# --- Production deployment rules (enforce in your host / pipeline) ---
# - Set at least one public URL: NEXTAUTH_URL, AUTH_URL, or PUBLIC_SITE_URL (required for prod builds/runtime).
# - UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN for multi-instance rate limits.
# - DISABLE_LOCAL_DISK_UPLOAD=1 in non-docker local prod tests; production code rejects POST /api/upload anyway.
# - Never SUPPORT_MEMORY_FALLBACK=1 in real production.
# - Never ALLOW_MOCK_AUTH or NEXT_PUBLIC_MOCK_AUTH in real production except dedicated demo/staging.
# - Gate releases: npm run verify:prod (requires full secrets in env).

# --- RAG seed (opt-in; embeddings cost API usage) ---
# SEED_RAG=1
# Or run: npm run db:seed:rag:embed

# Optional: set PRISMA_LOG=1 to print Prisma error/warn logs in dev (default is quiet).
# PRISMA_LOG=1
