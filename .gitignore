# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Secrets: never commit real keys. `.env*` is ignored; only the template is tracked.
# (`.env.local`, `.env.development.local`, `.env.production.local`, etc. stay untracked.)
.env*
!.env.example

# vercel
.vercel

# Eva uploads (local disk)
/uploads

# prisma — local DB artifacts (wrong-CWD SQLite, or dev files)
/prisma/dev.db
/prisma/dev.db-journal
/prisma/ci.db
/prisma/ci.db-journal
/prisma/prisma/*.db
/prisma/prisma/*.db-journal

# Claude Code — local tool permission overrides (per developer / machine)
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts

# local sidebar export bundle (not tracked)
right-sidebar-bundle/
right-sidebar-bundle.zip
